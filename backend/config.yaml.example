# LinX (灵枢) Configuration
# This is an example configuration file. Copy to config.yaml and customize for your environment.
# Environment variables can be used with ${VAR_NAME} syntax.

# ============================================================================
# Platform Settings
# ============================================================================
platform:
  name: "LinX Platform"
  version: "1.0.0"
  environment: "development"  # Options: development, staging, production
  debug: true

# ============================================================================
# API Gateway Configuration
# ============================================================================
api:
  host: "0.0.0.0"
  port: 8000
  workers: 4
  
  # CORS Configuration
  cors:
    enabled: true
    origins:
      - "http://localhost:3000"
      - "http://localhost:5173"
      - "https://workforce.company.com"
    allow_credentials: true
    allow_methods: ["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
    allow_headers: ["*"]
  
  # Rate Limiting
  rate_limit:
    enabled: true
    requests_per_minute: 60
    requests_per_hour: 1000
    burst: 10
  
  # JWT Authentication
  jwt:
    secret_key: "${JWT_SECRET}"  # REQUIRED: Set in environment
    algorithm: "HS256"
    expiration_hours: 24
    refresh_expiration_days: 7
  
  # Request/Response Settings
  max_request_size_mb: 100
  timeout_seconds: 300

# ============================================================================
# Database Configuration
# ============================================================================
database:
  # PostgreSQL - Primary Database
  postgres:
    host: "localhost"
    port: 5432
    database: "workforce_platform"
    username: "platform_user"
    password: "${POSTGRES_PASSWORD}"  # REQUIRED: Set in environment
    
    # Connection Pool Settings
    pool_size: 20
    max_overflow: 10
    pool_timeout: 30
    pool_recycle: 3600
    
    # Performance Settings
    echo: false  # Set to true for SQL query logging
    echo_pool: false
    
    # SSL Settings
    ssl_mode: "prefer"  # Options: disable, allow, prefer, require, verify-ca, verify-full
    ssl_cert: null
    ssl_key: null
    ssl_root_cert: null
  
  # Milvus - Vector Database
  milvus:
    host: "localhost"
    port: 19530
    user: ""
    password: "${MILVUS_PASSWORD}"  # Optional
    
    # Collection Settings
    collection_prefix: "workforce_"
    
    # Index Configuration
    index_type: "IVF_FLAT"  # Options: FLAT, IVF_FLAT, IVF_SQ8, IVF_PQ, HNSW, ANNOY
    metric_type: "L2"  # Options: L2, IP (Inner Product), COSINE
    nlist: 1024  # Number of cluster units (for IVF indexes)
    nprobe: 16  # Number of units to query (for IVF indexes)
    
    # HNSW Index Parameters (if using HNSW)
    hnsw_m: 16
    hnsw_ef_construction: 200
    hnsw_ef: 64
    
    # Connection Settings
    timeout: 30
    
    # Partitioning Strategy
    enable_partitioning: true
    partition_by: "user_id"  # Options: user_id, timestamp, agent_id
  
  # Redis - Message Bus and Cache
  redis:
    host: "localhost"
    port: 6379
    password: "${REDIS_PASSWORD}"  # Optional
    db: 0
    
    # Connection Pool
    max_connections: 50
    socket_timeout: 5
    socket_connect_timeout: 5
    
    # Retry Settings
    retry_on_timeout: true
    max_retries: 3
    
    # SSL Settings
    ssl: false
    ssl_cert_reqs: "required"
    ssl_ca_certs: null

# ============================================================================
# Object Storage Configuration (MinIO)
# ============================================================================
storage:
  minio:
    endpoint: "localhost:9000"
    # Optional browser-facing endpoint for presigned URLs.
    # Set this to a LAN IP / public hostname when the backend uses localhost internally.
    # public_endpoint: "192.168.0.29:9000"
    access_key: "${MINIO_ACCESS_KEY}"  # REQUIRED: Set in environment
    secret_key: "${MINIO_SECRET_KEY}"  # REQUIRED: Set in environment
    secure: false  # Set to true for HTTPS
    region: "us-east-1"
    
    # Bucket Configuration
    buckets:
      documents: "documents"
      audio: "audio"
      video: "video"
      images: "images"
      artifacts: "agent-artifacts"
      backups: "backups"
    
    # Upload Settings
    max_file_size_mb: 500
    allowed_document_types:
      - "pdf"
      - "doc"
      - "docx"
      - "pptx"
      - "xls"
      - "xlsx"
      - "txt"
      - "md"
      - "html"
    allowed_audio_types:
      - "mp3"
      - "wav"
      - "m4a"
      - "flac"
    allowed_video_types:
      - "mp4"
      - "avi"
      - "mov"
      - "mkv"
    allowed_image_types:
      - "png"
      - "jpg"
      - "jpeg"
      - "gif"
      - "bmp"
    
    # Versioning
    enable_versioning: true
    
    # Lifecycle Policies
    temp_file_retention_days: 7
    backup_retention_days: 90

# ============================================================================
# LLM Provider Configuration
# ============================================================================
llm:
  # Default provider selection
  default_provider: "ollama"  # Options: ollama, vllm, openai, anthropic
  
  # Fallback behavior
  enable_fallback: false
  fallback_order: ["ollama", "vllm"]
  
  # Request Settings
  timeout_seconds: 120
  max_retries: 3
  retry_delay_seconds: 2
  
  # Ollama Configuration (Primary - Remote)
  providers:
    ollama:
      enabled: true
      host: "192.168.0.29"
      port: 11434
      base_url: "http://192.168.0.29:11434"
      
      # Model Configuration
      models:
        chat: "qwen3-vl:30b"
        code: "qwen3-vl:30b"
        embedding: "nomic-embed-text"
        summarization: "qwen3-vl:30b"
        translation: "qwen3-vl:30b"
      
      # Generation Parameters
      temperature: 0.7
      top_p: 0.9
      top_k: 40
      num_predict: 2048
      repeat_penalty: 1.1
      
      # Context Settings
      context_window: 8192
      num_ctx: 8192
    
    # vLLM Configuration (High-Performance - Local)
    vllm:
      enabled: false
      host: "localhost"
      port: 8000
      base_url: "http://localhost:8000"
      
      # Model Configuration
      models:
        chat: "meta-llama/Llama-3-70b"
        code: "codellama/CodeLlama-13b-hf"
      
      # Performance Settings
      gpu_memory_utilization: 0.9
      max_num_seqs: 256
      max_model_len: 8192
    
    # OpenAI Configuration (Optional - Cloud)
    openai:
      enabled: false
      api_key: "${OPENAI_API_KEY}"  # Optional: Set in environment
      organization: ""
      
      # Model Configuration
      models:
        chat: "gpt-4"
        code: "gpt-4"
        embedding: "text-embedding-3-large"
        summarization: "gpt-3.5-turbo"
      
      # Generation Parameters
      temperature: 0.7
      max_tokens: 2048
      top_p: 1.0
      frequency_penalty: 0.0
      presence_penalty: 0.0
    
    # Anthropic Configuration (Optional - Cloud)
    anthropic:
      enabled: false
      api_key: "${ANTHROPIC_API_KEY}"  # Optional: Set in environment
      
      # Model Configuration
      models:
        chat: "claude-3-opus-20240229"
        code: "claude-3-opus-20240229"
        summarization: "claude-3-sonnet-20240229"
      
      # Generation Parameters
      temperature: 0.7
      max_tokens: 4096
      top_p: 1.0
      top_k: 40

# ============================================================================
# Agent Framework Configuration
# ============================================================================
agents:
  # Agent Pool Settings
  pool:
    min_size: 10
    max_size: 100
    idle_timeout_minutes: 5
    warmup_enabled: true
    warmup_count: 5
  
  # Default Resource Limits
  resources:
    default_cpu_cores: 1.0
    default_memory_gb: 2
    max_cpu_cores: 4
    max_memory_gb: 8
    default_disk_gb: 10
    max_disk_gb: 50
  
  # Agent Templates
  templates:
    - name: "data_analyst"
      display_name: "Data Analyst"
      description: "Analyzes data, creates visualizations, and generates reports"
      skills:
        - "data_processing"
        - "statistical_analysis"
        - "visualization"
        - "sql_query"
      default_cpu: 2.0
      default_memory: 4
    
    - name: "content_writer"
      display_name: "Content Writer"
      description: "Creates, edits, and summarizes written content"
      skills:
        - "writing"
        - "editing"
        - "summarization"
        - "translation"
      default_cpu: 1.0
      default_memory: 2
    
    - name: "code_assistant"
      display_name: "Code Assistant"
      description: "Writes, debugs, and reviews code"
      skills:
        - "code_generation"
        - "debugging"
        - "code_review"
        - "testing"
      default_cpu: 2.0
      default_memory: 4
    
    - name: "research_assistant"
      display_name: "Research Assistant"
      description: "Gathers information, conducts research, and compiles reports"
      skills:
        - "information_gathering"
        - "web_search"
        - "summarization"
        - "citation"
      default_cpu: 1.0
      default_memory: 2
  
  # Agent Execution Settings
  execution:
    max_task_duration_minutes: 60
    heartbeat_interval_seconds: 30
    max_retries: 3
    retry_delay_seconds: 5

# ============================================================================
# Code Execution Sandbox Configuration
# ============================================================================
code_execution:
  # Sandbox Selection
  sandbox_mode: "auto"  # Options: auto, gvisor, firecracker, docker
  
  # Fallback Behavior
  fallback_enabled: true
  fallback_to_docker: true
  warn_on_fallback: true
  require_minimum_security: "medium"  # Options: low, medium, high, very_high
  
  # Platform-Specific Overrides
  platform_overrides:
    linux:
      preferred: "gvisor"
      fallback: ["firecracker", "docker"]
    darwin:  # macOS
      preferred: "docker"
      fallback: []
    windows:
      preferred: "docker"
      fallback: []
  
  # Resource Limits
  resources:
    default_cpu_cores: 0.5
    max_cpu_cores: 2.0
    default_memory_mb: 512
    max_memory_mb: 2048
    default_timeout_seconds: 30
    max_timeout_seconds: 300
    max_disk_io_mbps: 10
    max_network_bandwidth_mbps: 1
    max_network_connections: 5
  
  # Security Settings
  security:
    enable_network: false
    allowed_domains: []
    block_dangerous_imports: true
    enable_static_analysis: true
    read_only_filesystem: true
  
  # Sandbox Pool
  pool:
    enabled: true
    size: 10
    warmup_on_startup: true

# ============================================================================
# Security Configuration
# ============================================================================
security:
  # Encryption Settings
  encryption:
    at_rest: true
    in_transit: true
    algorithm: "AES-256-GCM"
  
  # Data Classification
  data_classification:
    enabled: true
    auto_classify: true
    levels:
      - "public"
      - "internal"
      - "confidential"
      - "restricted"
    default_level: "internal"
  
  # Container Isolation
  container_isolation:
    drop_capabilities:
      - "NET_RAW"
      - "SYS_ADMIN"
      - "SYS_PTRACE"
      - "SYS_MODULE"
      - "DAC_OVERRIDE"
    read_only_root: true
    no_new_privileges: true
    seccomp_profile: "default"  # Path to custom seccomp profile or "default"
    apparmor_profile: "docker-default"
  
  # Network Security
  network:
    enable_firewall: true
    default_policy: "deny"
    allowed_internal_ports: [8000, 5432, 19530, 6379, 9000]
    block_external_access: true
  
  # Authentication
  authentication:
    password_min_length: 12
    password_require_uppercase: true
    password_require_lowercase: true
    password_require_numbers: true
    password_require_special: true
    max_login_attempts: 5
    lockout_duration_minutes: 30
  
  # Session Management
  session:
    max_concurrent_sessions: 5
    idle_timeout_minutes: 30
    absolute_timeout_hours: 24

# ============================================================================
# Resource Quotas
# ============================================================================
quotas:
  # Default Quotas for New Users
  default:
    max_agents: 10
    max_storage_gb: 100
    max_cpu_cores: 10
    max_memory_gb: 20
    max_concurrent_tasks: 50
    max_knowledge_items: 1000
  
  # Admin Quotas
  admin:
    max_agents: 100
    max_storage_gb: 1000
    max_cpu_cores: 100
    max_memory_gb: 200
    max_concurrent_tasks: 500
    max_knowledge_items: 10000
  
  # Quota Enforcement
  enforcement:
    enabled: true
    warn_at_percentage: 80
    block_at_percentage: 100

# ============================================================================
# Monitoring and Observability
# ============================================================================
monitoring:
  # Prometheus Metrics
  prometheus:
    enabled: true
    port: 9090
    path: "/metrics"
    
    # Metric Collection
    collect_system_metrics: true
    collect_application_metrics: true
    collect_business_metrics: true
    
    # Scrape Interval
    scrape_interval_seconds: 15
  
  # Logging Configuration
  logging:
    level: "INFO"  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
    format: "json"  # Options: json, text
    output: "stdout"  # Options: stdout, file, both
    timezone: "Asia/Shanghai"  # IANA timezone, e.g. Asia/Shanghai, UTC
    
    # File Logging (if output includes "file")
    file:
      path: "/var/log/workforce-platform"
      filename: "platform.log"
      max_size_mb: 100
      max_files: 10
      rotation: "daily"  # Options: daily, size
    
    # Structured Logging
    include_timestamp: true
    include_level: true
    include_caller: true
    include_correlation_id: true
    
    # Component-Specific Levels
    components:
      api_gateway: "INFO"
      task_manager: "INFO"
      agent_framework: "INFO"
      memory_system: "INFO"
      llm_providers: "WARNING"
      database: "WARNING"
  
  # Distributed Tracing
  tracing:
    enabled: true
    provider: "jaeger"  # Options: jaeger, zipkin, otlp
    
    # Jaeger Configuration
    jaeger:
      agent_host: "localhost"
      agent_port: 6831
      collector_endpoint: "http://localhost:14268/api/traces"
      
    # Sampling
    sample_rate: 0.1  # 10% of requests
    sample_errors: true  # Always sample errors
    
    # Trace Context
    propagate_context: true
  
  # Health Checks
  health:
    enabled: true
    endpoint: "/health"
    interval_seconds: 30
    timeout_seconds: 5
    
    # Component Health Checks
    check_database: true
    check_redis: true
    check_minio: true
    check_milvus: true
    check_funasr: true
    check_llm: true

# ============================================================================
# Alerting Configuration
# ============================================================================
alerting:
  enabled: true
  
  # Alert Channels
  channels:
    # Email Alerts
    email:
      enabled: false
      smtp_host: "smtp.gmail.com"
      smtp_port: 587
      smtp_user: "${SMTP_USER}"
      smtp_password: "${SMTP_PASSWORD}"
      from_address: "alerts@company.com"
      to_addresses:
        - "admin@company.com"
        - "ops@company.com"
      use_tls: true
    
    # Slack Alerts
    slack:
      enabled: false
      webhook_url: "${SLACK_WEBHOOK_URL}"
      channel: "#workforce-alerts"
      username: "Workforce Platform"
      icon_emoji: ":robot_face:"
    
    # Microsoft Teams Alerts
    teams:
      enabled: false
      webhook_url: "${TEAMS_WEBHOOK_URL}"
    
    # PagerDuty (Critical Alerts)
    pagerduty:
      enabled: false
      integration_key: "${PAGERDUTY_INTEGRATION_KEY}"
      severity_threshold: "critical"
  
  # Alert Rules
  rules:
    # System Alerts
    system:
      cpu_threshold: 90
      memory_threshold: 95
      disk_threshold: 85
      
    # Application Alerts
    application:
      error_rate_threshold: 5  # percentage
      task_failure_rate_threshold: 10  # percentage
      api_latency_p99_threshold_ms: 5000
      
    # Security Alerts
    security:
      failed_auth_attempts_per_minute: 10
      unauthorized_access_attempts: 1
      
    # Business Alerts
    business:
      task_queue_depth_threshold: 100
      agent_pool_exhausted: true
  
  # Alert Routing
  routing:
    critical: ["pagerduty", "slack", "email"]
    high: ["slack", "email"]
    medium: ["slack"]
    low: ["email"]
  
  # Alert Deduplication
  deduplication:
    enabled: true
    window_minutes: 5
    
  # Alert Throttling
  throttling:
    enabled: true
    max_alerts_per_hour: 10

# ============================================================================
# Task Management Configuration
# ============================================================================
task_management:
  # Task Decomposition
  decomposition:
    max_depth: 5
    max_subtasks: 20
    use_llm: true
    llm_model: "chat"
  
  # Task Execution
  execution:
    default_timeout_minutes: 60
    max_timeout_minutes: 480
    enable_parallel: true
    max_parallel_tasks: 10
    
  # Task Retry
  retry:
    enabled: true
    max_attempts: 3
    backoff_strategy: "exponential"  # Options: fixed, exponential
    initial_delay_seconds: 5
    max_delay_seconds: 300
  
  # Result Aggregation
  aggregation:
    default_strategy: "concatenation"  # Options: concatenation, summarization, structured_merge, voting
    use_llm_for_summarization: true

# ============================================================================
# Reset-Era User Memory / Skill Learning Configuration
# ============================================================================
user_memory:
  embedding:
    provider: "llm-pool"  # Preferred embedding provider for user-memory retrieval
    model: "BAAI/bge-m3"
    dimension: 1024
    batch_size: 32  # Max items per embedding batch request
    inherit_from_knowledge_base: true

  retrieval:
    hybrid_enabled: true
    similarity_threshold: 0.3
    vector:
      candidate_top_k: 40
      collection_prefix: "user_memory_embeddings_v2"
      metric_type: "IP"
      nprobe: 16
    lexical:
      enabled: true
      top_k: 30
      fts_enabled: true
      trigram_enabled: true
    structured:
      enabled: true
      top_k: 20
    fusion:
      method: "rrf"
      rrf_k: 60
    rerank:
      enabled: true
      provider: ""
      model: ""
      top_k: 30
      weight: 0.75
      timeout_seconds: 8
      failure_backoff_seconds: 30
      doc_max_chars: 1200
    planner:
      runtime_mode: "light"
      api_mode: "full"
      provider: ""
      model: ""
      timeout_seconds: 4
      failure_backoff_seconds: 60
      max_query_variants: 3
    reflection:
      enabled_api: true
      max_rounds: 1
      min_results: 3
      min_score: 0.45

  extraction:
    provider: ""  # Defaults to llm.default_provider when blank
    model: ""  # Auto-select first chat-capable model from provider when blank
    timeout_seconds: 120
    max_facts: 10
    max_preference_facts: 10
    enable_heuristic_fallback: true
    secondary_recall_enabled: true
    failure_backoff_seconds: 60
    fail_closed_empty_writes: true

  conversation_extraction:
    enabled: true
    run_on_startup: true
    startup_delay_seconds: 30
    interval_seconds: 300
    idle_timeout_minutes: 30
    overlap_turns: 2
    max_new_turns_per_run: 8
    max_batches_per_invocation: 3
    advisory_lock_id: 73012024
    use_advisory_lock: true
    run_lease_seconds: 300
    scan_limit: 200

  consolidation:
    enabled: true
    run_on_startup: true
    startup_delay_seconds: 180
    interval_seconds: 21600
    dry_run: false
    limit: 5000
    advisory_lock_id: 73012020
    use_advisory_lock: true

  observability:
    enable_quality_counters: true

  vector_indexing:
    enabled: true
    run_on_startup: true
    startup_delay_seconds: 10
    poll_interval_seconds: 5
    batch_size: 32
    stale_lock_seconds: 900
    max_attempts: 8
    retry_backoff_seconds: 30

  vector_cleanup:
    enabled: true
    run_on_startup: true
    startup_delay_seconds: 300
    interval_seconds: 21600
    dry_run: false
    batch_size: 500
    compact_on_cycle: true
    advisory_lock_id: 73012023
    use_advisory_lock: true

skill_learning:
  extraction:
    provider: ""  # Defaults to llm.default_provider when blank
    model: ""  # Auto-select first chat-capable model from provider when blank
    timeout_seconds: 120
    max_proposals: 6
    failure_backoff_seconds: 60

  publish_policy:
    skill_type: "agent_skill"
    storage_type: "inline"
    reuse_existing_by_name: true

session_ledger:
  enabled: true
  retention_days: 14
  run_on_startup: true
  startup_delay_seconds: 120
  cleanup_interval_seconds: 21600
  batch_size: 1000
  dry_run: false
  advisory_lock_id: 73012021
  use_advisory_lock: true

runtime_context:
  enable_user_memory: true
  enable_skills: true
  enable_knowledge_base: true

integrations:
  feishu:
    long_connection:
      poll_interval_seconds: 5
      proxy_mode: system  # direct | system | explicit
      proxy_url: ""  # Required when proxy_mode=explicit

# ============================================================================
# Knowledge Base Configuration
# ============================================================================
knowledge_base:
  # Document Processing
  processing:
    # Chunking Strategy
    chunk_size_tokens: 512
    chunk_overlap_tokens: 50
    
    # OCR Settings
    ocr:
      enabled: true
      engine: "tesseract"
      languages: ["eng", "chi_sim"]
      confidence_threshold: 0.7
    
    # Audio Transcription
    transcription:
      enabled: true
      engine: "funasr"
      model: "iic/SenseVoiceSmall"  # Default FunASR model
      language: "auto"
      funasr_service_url: "http://127.0.0.1:10095"  # Optional external FunASR service
      funasr_service_timeout_seconds: 300
      funasr_service_api_key: ""  # Optional bearer token for service auth
    
    # Video Processing
    video:
      extract_audio: true
      extract_frames: false
      frame_interval_seconds: 10

    # Milvus indexing resilience
    indexing:
      flush_timeout_seconds: 8
      milvus_max_retries: 2
      retry_backoff_seconds: 1
      allow_flush_degrade: true

  # Vision Parsing
  parsing:
    method: "auto"
    vision_model: "qwen3-vl:30b"
    vision_provider: "ollama"
    vision_timeout_seconds: 120
    output_language: "zh-CN"
  
  # Processing Queue
  queue:
    max_concurrent_jobs: 5
    job_timeout_minutes: 60
    retry_failed_jobs: true
    max_retries: 3
  
  # Search Configuration
  search:
    max_concurrent_requests: 4
    request_timeout_seconds: 30
    enable_semantic: true
    enable_fulltext: true
    combine_results: true
    semantic_weight: 0.7
    fulltext_weight: 0.3
    fusion_method: "rrf"
    rrf_k: 60
    min_relevance_score: 0.3
    hybrid_score_scale: 0.02
    keyword_min_rank: 4.0
    keyword_max_terms: 16
    semantic_timeout_seconds: 8
    embedding_failure_backoff_seconds: 30
    rerank_enabled: true
    rerank_weight: 0.85
    rerank_provider: "llm-pool"
    rerank_model: "BAAI/bge-reranker-v2-m3"
    rerank_top_k: 30
    rerank_timeout_seconds: 10
    rerank_failure_backoff_seconds: 60
    rerank_doc_max_chars: 1600
    cross_language_expansion_enabled: true
    cross_language_languages:
      - "en"
      - "zh-CN"
    cross_language_provider: ""  # default to llm.default_provider when empty
    cross_language_model: ""  # auto-select first chat-capable model from provider
    cross_language_timeout_seconds: 4
    cross_language_failure_backoff_seconds: 60
    cross_language_max_expansions: 2
    cross_language_max_queries: 3

# ============================================================================
# Message Bus Configuration
# ============================================================================
message_bus:
  # Message Types
  enable_pubsub: true
  enable_streams: true
  enable_queues: true
  
  # Message Retention
  retention:
    pubsub_ttl_seconds: 3600
    stream_max_length: 10000
    stream_ttl_days: 7
  
  # Consumer Groups
  consumer_groups:
    enabled: true
    max_consumers_per_group: 10
  
  # Message Serialization
  serialization: "json"  # Options: json, msgpack, pickle
  
  # Audit Logging
  audit_messages: true

# ============================================================================
# Deployment Configuration
# ============================================================================
deployment:
  # Deployment Mode
  mode: "docker-compose"  # Options: docker-compose, kubernetes, standalone
  
  # Docker Compose Settings
  docker_compose:
    project_name: "workforce-platform"
    network_name: "workforce-network"
    
  # Kubernetes Settings
  kubernetes:
    namespace: "workforce-platform"
    enable_autoscaling: true
    min_replicas: 2
    max_replicas: 10
    target_cpu_utilization: 70
    
    # RuntimeClass for gVisor (Linux only)
    use_gvisor: true
    runtime_class: "gvisor"
  
  # Backup Configuration
  backup:
    enabled: true
    schedule: "0 2 * * *"  # Daily at 2 AM
    retention_days: 30
    backup_location: "backups"
    
    # Backup Components
    backup_postgres: true
    backup_milvus: true
    backup_minio: true
    backup_redis: false

# ============================================================================
# Feature Flags
# ============================================================================
features:
  # Core Features
  enable_task_flow_visualization: true
  enable_real_time_updates: true
  enable_websocket: true
  
  # Advanced Features
  enable_dynamic_skill_generation: false
  enable_robot_integration: false
  enable_multi_tenancy: false
  
  # Experimental Features
  enable_advanced_analytics: false
  enable_cost_tracking: false
  enable_anomaly_detection: false

# ============================================================================
# Development Settings
# ============================================================================
development:
  # Debug Settings
  debug_mode: true
  verbose_logging: true
  enable_profiling: false
  
  # Hot Reload
  hot_reload: true
  watch_files: true
  
  # Testing
  enable_test_mode: false
  mock_llm_responses: false
  mock_external_services: false
  
  # Sample Data
  load_sample_data: false
  sample_users: 5
  sample_agents: 10
  sample_tasks: 20
