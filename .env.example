# Application
APP_NAME=LinX
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Frontend
FRONTEND_URL=http://localhost:3000

# Database - PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=linx
POSTGRES_USER=linx
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Vector Database - Milvus
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_USER=root
MILVUS_PASSWORD=Milvus

# Object Storage - MinIO
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_PREFIX=linx

# Message Bus - Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LLM Provider
LLM_PROVIDER=ollama  # ollama, vllm, openai, anthropic
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama2
VLLM_HOST=http://vllm:8000
VLLM_MODEL=meta-llama/Llama-2-7b-chat-hf

# Optional: Cloud LLM (fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# Security
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Encryption
ENCRYPTION_KEY=your-encryption-key-32-bytes-long

# Resource Limits
MAX_AGENTS_PER_USER=10
MAX_STORAGE_GB_PER_USER=100
MAX_CPU_CORES_PER_AGENT=2
MAX_MEMORY_GB_PER_AGENT=4

# Code Execution Sandbox
SANDBOX_MODE=auto  # auto, gvisor, firecracker, docker
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MAX_CPU=0.5
SANDBOX_MAX_MEMORY_MB=512

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# File Upload
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=pdf,docx,txt,md,mp3,wav,m4a,mp4,avi,mov,png,jpg,gif

# Task Management
MAX_TASK_DEPTH=5
TASK_TIMEOUT_MINUTES=60

# Agent Configuration
AGENT_HEARTBEAT_INTERVAL_SECONDS=30
AGENT_MAX_IDLE_TIME_MINUTES=10
